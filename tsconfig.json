{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@packforge/core": ["packages/core/src/index.ts"],
      "@packforge/packs": ["packages/packs/src/index.ts"],
      "@packforge/packs/coffee-shop": ["packages/packs/src/coffee-shop/index.ts"],
      "@packforge/packs/game-studio": ["packages/packs/src/game-studio/index.ts"],
      "@packforge/packs/space-colony": ["packages/packs/src/space-colony/index.ts"],
      "@packforge/packs/scrapyard": ["packages/packs/src/scrapyard/index.ts"],
      "@packforge/builder-kit": ["packages/builder-kit/src/index.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["vitest/globals", "node"]
  },
  "include": ["src", "packages", "tests", "vite.config.ts", "playwright.config.ts"]
}
